flowchart TD
    subgraph Input["输入"]
        AW_JSON["📋 AW 输入 JSON<br/>（含文件路径列表）"]
        AW_PY["📄 Python AW 函数源文件<br/>（def aw_* 函数）"]
    end

    subgraph Pipeline["清洗管道"]
        direction TB
        READ["① Read<br/>AWJsonReader<br/>─────────────<br/>读取 JSON 获取路径列表<br/>加载所有 .py 源文件"]
        PARSE["② Parse<br/>ASTParseStage + AWFunctionParser<br/>─────────────<br/>AST 解析 def aw_* 函数<br/>提取函数名 + docstring + 函数体源码"]
        EXTRACT["③ Extract<br/>DocstringExtractStage + AWDocstringParser<br/>─────────────<br/>解析函数 docstring<br/>提取函数功能描述"]
        ENRICH["④ Enrich<br/>AWEnrichStage<br/>─────────────<br/>组装 AWCorpusItem<br/>（函数名 + 描述 + 实现代码）"]
        WRITE["⑤ Write<br/>AWAggregateWriter<br/>─────────────<br/>聚合所有 AW 输出单个 JSON"]
    end

    subgraph Output["输出"]
        AW_OUT["📋 聚合 JSON<br/>（所有 AW 的功能描述 + 实现代码）"]
    end

    AW_JSON --> READ
    AW_PY --> READ
    READ --> PARSE
    PARSE --> EXTRACT
    EXTRACT --> ENRICH
    ENRICH --> WRITE
    WRITE --> AW_OUT

    style READ fill:#4A90D9,color:#fff
    style PARSE fill:#4A90D9,color:#fff
    style EXTRACT fill:#4A90D9,color:#fff
    style ENRICH fill:#D94A4A,color:#fff
    style WRITE fill:#4A90D9,color:#fff
